# ---------------------------------------------------------------------------
# Stripe (Pro tier)
# ---------------------------------------------------------------------------
# Billing is OFF until STRIPE_SECRET_KEY is set. When unset (or when
# AGENTDASH_BILLING_DISABLED=true), Pro caps are bypassed for local dev.
# When set in production, caps are enforced (Free: 1 human + 1 agent; Pro:
# unlimited) and the webhook signature is verified on every event.

# Stripe API secret key (test mode: sk_test_..., live: sk_live_...).
STRIPE_SECRET_KEY=

# Signing secret for the Stripe webhook endpoint (whsec_...). Used to verify
# every POST /api/billing/webhook payload. An empty value makes the webhook
# route reject all events with 503 — never leave this blank in production.
STRIPE_WEBHOOK_SECRET=

# Price id for the Pro per-seat subscription (price_...). Used as the line item
# on the Checkout Session created by POST /api/billing/checkout-session.
STRIPE_PRO_PRICE_ID=

# Length of the no-card trial, in days. Applied as subscription_data
# .trial_period_days on the Checkout Session (the 14-day default matches the
# product spec).
STRIPE_TRIAL_DAYS=14

# Public base URL used to build Stripe success/cancel/return redirect URLs and
# the "Manage subscription" links in trial-ending emails (e.g.
# https://app.agentdash.com).
BILLING_PUBLIC_BASE_URL=
# Plugin UI CORS allowlist (authenticated deployments only)
# Comma-separated list of origins permitted to load plugin UI bundles
# cross-origin (e.g. a separate plugin dev server or admin console). In
# local_trusted/dev the plugin-UI route stays permissive (Access-Control-
# Allow-Origin: *). In authenticated mode it restricts to this allowlist plus
# the instance's own public origin (PAPERCLIP_PUBLIC_URL); arbitrary Origin
# headers are never reflected. Leave unset to allow only same-origin.
# AGENTDASH_PLUGIN_UI_ALLOWED_ORIGINS=https://plugins.example.com,https://admin.example.com

# ---------------------------------------------------------------------------
# Slack Connector (AGE-108)
# ---------------------------------------------------------------------------
# Slack integration is OFF until SLACK_CLIENT_ID and SLACK_CLIENT_SECRET are
# set. Configure a Slack App at https://api.slack.com/apps with OAuth v2,
# Event Subscriptions (Request URL: {AGENTDASH_PUBLIC_BASE_URL}/api/connectors/slack/events),
# and Interactive Components (Request URL: {AGENTDASH_PUBLIC_BASE_URL}/api/connectors/slack/interactions).

# Slack App OAuth2 client credentials.
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# Slack signing secret — used to verify inbound event and interaction payloads.
# Found under "Basic Information > App Credentials" in your Slack app settings.
SLACK_SIGNING_SECRET=

# Public base URL of this AgentDash instance (used for OAuth redirect URI).
# Defaults to http://localhost:3100 in dev.
# AGENTDASH_PUBLIC_BASE_URL=https://app.agentdash.com
# Google OAuth (Gmail Connector — AGE-109)
# ---------------------------------------------------------------------------
# Required for Gmail read/send. Create credentials at
# https://console.cloud.google.com/apis/credentials (OAuth 2.0 Client ID,
# type "Web application"). Enable the Gmail API in the same GCP project.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# CoS chat LLM dispatch (server/src/services/dispatch-llm.ts)
# AGENTDASH_DEFAULT_ADAPTER selects the provider: claude_api (Anthropic, default),
# minimax, openai_compat, hermes_local, or claude_local. Unset/unkeyed => stub replies.
# AGENTDASH_DEFAULT_ADAPTER=minimax
#
# MiniMax via its Anthropic-compatible Messages API (adapter "minimax").
# MINIMAX_API_KEY=...                                  # required to leave stub mode
# MINIMAX_BASE_URL=https://api.minimaxi.com/anthropic  # default; SDK posts to /v1/messages
# MINIMAX_MODEL=MiniMax-M3                             # default (M2.x also valid)
# MINIMAX_MAX_TOKENS=1024                              # default
#
# OpenAI-compatible provider (adapter "openai_compat") — OpenRouter / Fireworks /
# Together / Groq. Usage-based inference for the Cloud SKU. Fetch to {base}/chat/completions.
# OPENAI_COMPAT_API_KEY=...                            # required to leave stub mode
# OPENAI_COMPAT_BASE_URL=https://openrouter.ai/api/v1  # default
# OPENAI_COMPAT_MODEL=openai/gpt-4o-mini               # default
# OPENAI_COMPAT_MAX_TOKENS=1024                        # default
#
# Native Anthropic path (adapter "claude_api"):
# ANTHROPIC_API_KEY=sk-ant-...

# Usage-based billing (Cloud SKU, G4) — bills metered inference (cost_events).
# Billable = max(provider COGS, token-priced COGS) * markup.
# AGENTDASH_USAGE_MARKUP=1.5                 # multiplier over COGS (default 1.5)
# AGENTDASH_USAGE_INPUT_CENTS_PER_MTOK=0     # floor price per 1M input tokens (cents)
# AGENTDASH_USAGE_OUTPUT_CENTS_PER_MTOK=0    # floor price per 1M output tokens (cents)
# STRIPE_USAGE_METER_EVENT=agentdash_usage   # Stripe Billing Meter event name (optional)

# Deployment SKU + on-prem license (G2). cloud (default) = managed + markup;
# on_prem = customer-hosted, BYO tokens, no markup.
# AGENTDASH_DEPLOYMENT_KIND=cloud            # cloud | on_prem
# AGENTDASH_ENFORCE_LICENSE=false            # when true + on_prem, unlicensed => 402 on gated routes
# AGENTDASH_LICENSE_KEY=...                   # signed license token (issued by AgentDash)
# AGENTDASH_LICENSE_PUBLIC_KEY=...            # ed25519 public key (SPKI PEM) to verify the license

# Agent Research (Agent Factory Research integration)
# Base URL of the Agent Research assessment service
RESEARCH_APP_URL=https://your-research-app.vercel.app
# API key for the Agent Research service
RESEARCH_APP_API_KEY=ark_...

# Error tracking (Sentry) — OPTIONAL, disabled by default.
# Uses a tiny built-in transport (global fetch) — no extra dependency required.
# Leave SENTRY_DSN unset to disable remote error tracking entirely (no-op).
# Set it to your project DSN to capture 5xx/unhandled server errors.
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# Clockchain attestation (feature-flagged; server-side only; off an agent's critical path)
AGENTDASH_ATTESTATION_ENABLED=false
CLOCKCHAIN_MCP_URL=https://mcp.clockchain.network/mcp
CLOCKCHAIN_MCP_KEY=
CLOCKCHAIN_MCP_TIMEOUT_MS=10000
# Proceed with writes while the validator pool is degraded (testnet/demo only).
# Off by default — leave false on mainnet so degraded writes are refused, not silently "anchored".
CLOCKCHAIN_ALLOW_DEGRADED=false
