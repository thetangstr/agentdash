# ---------------------------------------------------------------------------
# Stripe (Pro tier)
# ---------------------------------------------------------------------------
# Billing is OFF until STRIPE_SECRET_KEY is set. When unset (or when
# AGENTDASH_BILLING_DISABLED=true), Pro caps are bypassed for local dev.
# When set in production, caps are enforced (Free: 1 human + 1 agent; Pro:
# unlimited) and the webhook signature is verified on every event.

# Stripe API secret key (test mode: sk_test_..., live: sk_live_...).
STRIPE_SECRET_KEY=

# Signing secret for the Stripe webhook endpoint (whsec_...). Used to verify
# every POST /api/billing/webhook payload. An empty value makes the webhook
# route reject all events with 503 — never leave this blank in production.
STRIPE_WEBHOOK_SECRET=

# Price id for the Pro per-seat subscription (price_...). Used as the line item
# on the Checkout Session created by POST /api/billing/checkout-session.
STRIPE_PRO_PRICE_ID=

# Length of the no-card trial, in days. Applied as subscription_data
# .trial_period_days on the Checkout Session (the 14-day default matches the
# product spec).
STRIPE_TRIAL_DAYS=14

# Public base URL used to build Stripe success/cancel/return redirect URLs and
# the "Manage subscription" links in trial-ending emails (e.g.
# https://app.agentdash.com).
BILLING_PUBLIC_BASE_URL=
# Plugin UI CORS allowlist (authenticated deployments only)
# Comma-separated list of origins permitted to load plugin UI bundles
# cross-origin (e.g. a separate plugin dev server or admin console). In
# local_trusted/dev the plugin-UI route stays permissive (Access-Control-
# Allow-Origin: *). In authenticated mode it restricts to this allowlist plus
# the instance's own public origin (PAPERCLIP_PUBLIC_URL); arbitrary Origin
# headers are never reflected. Leave unset to allow only same-origin.
# AGENTDASH_PLUGIN_UI_ALLOWED_ORIGINS=https://plugins.example.com,https://admin.example.com

# Agent Research (Agent Factory Research integration)
# Base URL of the Agent Research assessment service
RESEARCH_APP_URL=https://your-research-app.vercel.app
# API key for the Agent Research service
RESEARCH_APP_API_KEY=ark_...
