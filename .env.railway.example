# AgentDash — Railway (hosted SaaS) environment template.
#
# Paste these into the Railway service's "Variables" tab (Raw Editor).
# Replace every CHANGEME. Do NOT commit real secrets.
#
# Full reference: doc/deploy/railway.md and doc/LAUNCH.md.

# --- deployment mode: public, real sign-in (no synthetic local-board user) ---
PAPERCLIP_DEPLOYMENT_MODE=authenticated
PAPERCLIP_DEPLOYMENT_EXPOSURE=public

# --- canonical public URL ---
# Use your Railway-generated domain. After the first deploy, copy the real
# subdomain here and redeploy (it is unknown until the service exists).
PAPERCLIP_AUTH_PUBLIC_BASE_URL=https://YOUR-APP.up.railway.app
BILLING_PUBLIC_BASE_URL=https://YOUR-APP.up.railway.app

# --- auth secret (REQUIRED) — server crashes on boot without it ---
# Generate once:  openssl rand -hex 32
BETTER_AUTH_SECRET=CHANGEME_run_openssl_rand_hex_32

# --- SSO (optional): "Continue with Google" / "Continue with Microsoft" ---
# Buttons on /auth stay HIDDEN until BOTH the id and secret of a provider are
# set, so you can deploy now and flip SSO on later by adding these + redeploy.
# Register these redirect URIs (swap in your PAPERCLIP_AUTH_PUBLIC_BASE_URL host):
#   Google:    https://YOUR-APP.up.railway.app/api/auth/callback/google
#   Microsoft: https://YOUR-APP.up.railway.app/api/auth/callback/microsoft
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
# MICROSOFT_TENANT_ID=common   # optional; defaults to "common" (any Microsoft account)

# --- database: reference Railway's Postgres plugin variable ---
DATABASE_URL=${{Postgres.DATABASE_URL}}

# --- apply migrations on every deploy (REQUIRED for cloud; else the container
#     exits whenever the schema is stale after a release) ---
PAPERCLIP_MIGRATION_AUTO_APPLY=true

# --- launch WITHOUT billing: leave STRIPE_SECRET_KEY UNSET — tier caps are then
#     bypassed (Free-tier usable). Do NOT set AGENTDASH_BILLING_DISABLED in public
#     cloud: the cloud preflight rejects it as a dev bypass and fails closed. Wire
#     Stripe later (see doc/LAUNCH.md) for the 14-day trial + Pro per-seat. ---
# STRIPE_SECRET_KEY=    # leave unset for the no-billing launch

# --- LLM provider (server-side secret; REQUIRED for real CoS replies) ---
# Without a key the CoS returns a stub reply and the cloud preflight fails
# closed. Pick ONE provider:
#   (a) Anthropic (default claude_api path):
ANTHROPIC_API_KEY=sk-ant-CHANGEME
#   (b) any OpenAI-compatible provider (OpenRouter / Fireworks / Together / Groq):
# AGENTDASH_DEFAULT_ADAPTER=openai_compat
# OPENAI_COMPAT_API_KEY=CHANGEME
# OPENAI_COMPAT_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_COMPAT_MODEL=anthropic/claude-3.7-sonnet

# HOST=0.0.0.0 and PORT are handled by the Dockerfile + Railway's injected $PORT.
# Do NOT set AGENTDASH_RATE_LIMIT_DISABLED / other dev bypasses in production —
# the cloud preflight fails closed if it finds one.
