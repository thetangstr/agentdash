<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>ai.agentdash.postgres</string>

	<key>ProgramArguments</key>
	<array>
		<string>/bin/sh</string>
		<string>-c</string>
		<string>
			# Load env vars
			. %%ENV_FILE%%
			DATA_DIR=%%HOME%%/.agentdash/data/postgres
			mkdir -p "$DATA_DIR"
			exec postgres -D "$DATA_DIR" -k "$DATA_DIR" -p 5432
		</string>
	</array>

	<key>RunAtLoad</key>
	<true/>

	<key>KeepAlive</key>
	<dict>
		<key>Crashed</key>
		<true/>
		<key>AfterInitialDemand</key>
		<true/>
	</dict>

	<key>StandardOutPath</key>
	<string>%%HOME%%/.agentdash/logs/postgres.log</string>

	<key>StandardErrorPath</key>
	<string>%%HOME%%/.agentdash/logs/postgres.err</string>

	<key>ProcessType</key>
	<string>Background</string>

	<key>ThrottleInterval</key>
	<integer>10</integer>

	<key>ExitTimeOut</key>
	<integer>30</integer>
</dict>
</plist>
