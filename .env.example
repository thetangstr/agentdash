DATABASE_URL=postgres://paperclip:paperclip@localhost:5432/paperclip
PORT=3100
SERVE_UI=false
BETTER_AUTH_SECRET=paperclip-dev-secret

# Discord webhook for daily merge digest (scripts/discord-daily-digest.sh)
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# CoS chat LLM dispatch (server/src/services/dispatch-llm.ts)
# AGENTDASH_DEFAULT_ADAPTER selects the provider: claude_api (Anthropic, default),
# minimax, openai_compat, hermes_local, or claude_local. Unset/unkeyed => stub replies.
# AGENTDASH_DEFAULT_ADAPTER=minimax
#
# MiniMax via its Anthropic-compatible Messages API (adapter "minimax").
# MINIMAX_API_KEY=...                                  # required to leave stub mode
# MINIMAX_BASE_URL=https://api.minimaxi.com/anthropic  # default; SDK posts to /v1/messages
# MINIMAX_MODEL=MiniMax-M3                             # default (M2.x also valid)
# MINIMAX_MAX_TOKENS=1024                              # default
#
# OpenAI-compatible provider (adapter "openai_compat") — OpenRouter / Fireworks /
# Together / Groq. Usage-based inference for the Cloud SKU. Fetch to {base}/chat/completions.
# OPENAI_COMPAT_API_KEY=...                            # required to leave stub mode
# OPENAI_COMPAT_BASE_URL=https://openrouter.ai/api/v1  # default
# OPENAI_COMPAT_MODEL=openai/gpt-4o-mini               # default
# OPENAI_COMPAT_MAX_TOKENS=1024                        # default
#
# Native Anthropic path (adapter "claude_api"):
# ANTHROPIC_API_KEY=sk-ant-...

# Usage-based billing (Cloud SKU, G4) — bills metered inference (cost_events).
# Billable = max(provider COGS, token-priced COGS) * markup.
# AGENTDASH_USAGE_MARKUP=1.5                 # multiplier over COGS (default 1.5)
# AGENTDASH_USAGE_INPUT_CENTS_PER_MTOK=0     # floor price per 1M input tokens (cents)
# AGENTDASH_USAGE_OUTPUT_CENTS_PER_MTOK=0    # floor price per 1M output tokens (cents)
# STRIPE_USAGE_METER_EVENT=agentdash_usage   # Stripe Billing Meter event name (optional)

# Agent Research (Agent Factory Research integration)
# Base URL of the Agent Research assessment service
RESEARCH_APP_URL=https://your-research-app.vercel.app
# API key for the Agent Research service
RESEARCH_APP_API_KEY=ark_...
