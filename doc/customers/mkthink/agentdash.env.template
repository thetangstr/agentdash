# MKThink AgentDash Environment Configuration
# Copy to ~/.config/agentdash/agentdash.env and fill in <VALUES>
# Generated 2026-07-23 for MKThink on-prem pilot (6-month free trial)

# === Deployment ===
PAPERCLIP_DEPLOYMENT_MODE=authenticated
NODE_ENV=production
PAPERCLIP_DEPLOYMENT_EXPOSURE=private
PAPERCLIP_BIND=lan
# Replace with the Mac mini's LAN IP or Tailscale hostname
PAPERCLIP_ALLOWED_HOSTNAMES=<MKTHINK-MAC-MINI-IP>
PAPERCLIP_PUBLIC_URL=http://<MKTHINK-MAC-MINI-IP>:3100
PAPERCLIP_API_URL=http://127.0.0.1:3100
PAPERCLIP_AUTH_BASE_URL_MODE=explicit
PAPERCLIP_AUTH_PUBLIC_BASE_URL=http://<MKTHINK-MAC-MINI-IP>:3100
PAPERCLIP_MIGRATION_AUTO_APPLY=true

# === Security (generate on-site with: openssl rand -hex 32) ===
BETTER_AUTH_SECRET=<GENERATE_ON_SITE>
PAPERCLIP_AGENT_JWT_SECRET=<GENERATE_ON_SITE>

# === LLM Adapter ===
# Option A: Claude API (recommended — full cost tracking + budget enforcement)
AGENTDASH_DEFAULT_ADAPTER=claude_api
ANTHROPIC_API_KEY=<CUSTOMER_ANTHROPIC_API_KEY>

# Option B: Claude Code CLI (uses subscription, no API key needed, but no cost tracking)
# AGENTDASH_DEFAULT_ADAPTER=claude_local
# DISABLE_AUTOUPDATER=1

# Option C: Local model via Ollama (free, no external dependency)
# AGENTDASH_DEFAULT_ADAPTER=openai_compat
# OPENAI_COMPAT_API_KEY=ollama
# OPENAI_COMPAT_BASE_URL=http://localhost:11434/v1
# OPENAI_COMPAT_MODEL=gemma4:12b

# === License ===
AGENTDASH_DEPLOYMENT_KIND=on_prem
AGENTDASH_LICENSE_KEY=eyJjdX...fFAQ
