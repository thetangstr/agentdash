# Release infrastructure ownership.
#
# Keep these owners in sync with actual repository collaborators before
# enabling branch protection's "Require review from Code Owners" setting.

.github/** @thetangstr
scripts/release*.sh @thetangstr
scripts/release-*.mjs @thetangstr
scripts/create-github-release.sh @thetangstr
scripts/rollback-latest.sh @thetangstr
doc/RELEASING.md @thetangstr
doc/PUBLISHING.md @thetangstr
doc/RELEASE-AUTOMATION-SETUP.md @thetangstr

# Package files — dependency changes require review
# package.json matches recursively at all depths (covers root + all workspaces)
package.json @thetangstr
pnpm-lock.yaml @thetangstr
pnpm-workspace.yaml @thetangstr
.npmrc @thetangstr
