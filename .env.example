# =============================================================================
# AgentDash Environment Configuration
# =============================================================================
# Copy this file to .env and fill in values:
#   cp .env.example .env
#
# For local development, most defaults work out of the box.
# For production/authenticated deployments, you MUST set BETTER_AUTH_SECRET.
# =============================================================================

# --- Database ----------------------------------------------------------------
# Leave unset for embedded PostgreSQL (auto-managed at ~/.paperclip/instances/)
# Set for external PostgreSQL (Docker, cloud, etc.)
DATABASE_URL=postgres://paperclip:paperclip@localhost:5432/paperclip

# --- Server ------------------------------------------------------------------
PORT=3100

# Serve the UI from the server (set true for Docker/production, false if running UI separately)
SERVE_UI=false

# --- Deployment Mode ---------------------------------------------------------
# "local_trusted" = no auth, local dev (default)
# "authenticated" = full auth required (production)
PAPERCLIP_DEPLOYMENT_MODE=local_trusted

# "private" = internal network only
# "public" = internet-facing (requires HTTPS)
PAPERCLIP_DEPLOYMENT_EXPOSURE=private

# The public URL where AgentDash is accessible (used for invite links, webhooks)
PAPERCLIP_PUBLIC_URL=http://localhost:3100

# --- Authentication (REQUIRED for authenticated mode) ------------------------
# Generate with: openssl rand -hex 32
# This secret signs session tokens. Keep it secret, keep it safe.
BETTER_AUTH_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32

# --- Migrations --------------------------------------------------------------
# Auto-apply database migrations on startup (recommended for Docker/CI)
# PAPERCLIP_MIGRATION_AUTO_APPLY=true

# --- LLM Integration (optional) ---------------------------------------------
# Required for onboarding context extraction and team suggestion features
# ANTHROPIC_API_KEY=sk-ant-...

# --- HubSpot (optional) ------------------------------------------------------
# Configure via the UI at /settings/hubspot instead of env vars
# HUBSPOT_ACCESS_TOKEN=pat-na1-...
# HUBSPOT_PORTAL_ID=12345678

# --- WorkOS AuthKit (cloud Pro tier — AGE-58) ---------------------------------
# Required when AUTH_PROVIDER=workos. Obtain from the WorkOS dashboard.
# AUTH_PROVIDER=workos
# WORKOS_API_KEY=sk_live_...
# WORKOS_CLIENT_ID=client_...
# Webhook signing secret from the WorkOS dashboard (Webhooks → Endpoint → Secret).
# WORKOS_WEBHOOK_SECRET=whsec_...

# --- Email delivery (AGE-59) -------------------------------------------------
# EMAIL_BACKEND selects the transactional email backend.
# "relay"  = AgentDash-hosted Resend relay (self-hosted Free, default when AUTH_PROVIDER=better-auth)
# "workos" = WorkOS-managed + direct Resend (cloud Pro, default when AUTH_PROVIDER=workos)
# EMAIL_BACKEND=relay

# Self-hosted relay settings (relay backend only):
# URL of the AgentDash-hosted Resend relay endpoint.
# EMAIL_RELAY_URL=https://relay.agentdash.com/transactional
# Stable identifier for this AgentDash instance (used for per-instance rate limiting at the relay).
# EMAIL_RELAY_INSTANCE_ID=my-company-instance
# HMAC-SHA256 key for signing relay payloads. Generate with: openssl rand -hex 32
# EMAIL_RELAY_SIGNING_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32

# Resend API key (workos backend — direct sends for join-request notifications + welcome emails).
# RESEND_API_KEY=re_...
