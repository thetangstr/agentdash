<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>ai.agentdash.agent</string>

	<key>ProgramArguments</key>
	<array>
		<string>/bin/sh</string>
		<string>-c</string>
		<string>
			# Load env vars
			set -a
			. %%ENV_FILE%%
			set +a

			# Ensure log directory exists
			mkdir -p %%LOG_DIR%%

			# Start the server from the source checkout. The build step still
			# verifies TypeScript and prepares ui/dist for static serving.
			cd %%APP_DIR%%
			exec %%PNPM_BIN%% --filter @paperclipai/server exec tsx src/index.ts
		</string>
	</array>

	<key>RunAtLoad</key>
	<true/>

	<key>KeepAlive</key>
	<dict>
		<key>Crashed</key>
		<true/>
		<key>AfterInitialDemand</key>
		<true/>
	</dict>

	<key>EnvironmentVariables</key>
	<dict>
		<key>PAPERCLIP_HOME</key>
		<string>%%HOME%%/.agentdash</string>
		<key>PATH</key>
		<string>%%PATH_VALUE%%</string>
	</dict>

	<key>StandardOutPath</key>
	<string>%%HOME%%/.agentdash/logs/agentdash.log</string>

	<key>StandardErrorPath</key>
	<string>%%HOME%%/.agentdash/logs/agentdash.err</string>

	<key>ProcessType</key>
	<string>Background</string>

	<key>ThrottleInterval</key>
	<integer>10</integer>

	<key>ExitTimeOut</key>
	<integer>30</integer>

	<key>HardResourceLimits</key>
	<dict>
		<key>NumberOfFiles</key>
		<integer>1024</integer>
	</dict>
</dict>
</plist>
